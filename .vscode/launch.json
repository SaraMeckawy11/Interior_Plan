{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Floor Plan Studio (plan2.py)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/plan2.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Run current file",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        }
    ]
}
